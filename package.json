{
  "name": "zerion-cli",
  "version": "1.0.0",
  "description": "Zerion for AI agents and developers: wallet-analysis skill bundle and a JSON-first CLI.",
  "author": "Zerion",
  "type": "module",
  "bin": {
    "zerion": "./zerion.js",
    "aegis": "./engine/index.mjs"
  },
  "files": [
    "zerion.js",
    "router.js",
    "commands/",
    "utils/",
    "policies/",
    "engine/**/*.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node --env-file=.env engine/index.mjs",
    "demo": "node --env-file=.env scripts/demo.mjs",
    "test": "node --test 'tests/unit/**/*.test.mjs'",
    "test:unit": "node --test 'tests/unit/**/*.test.mjs'",
    "test:integration": "node --test --test-concurrency=1 'tests/integration/**/*.test.mjs'",
    "test:integration:auth": "node --test tests/integration/auth.test.mjs",
    "test:engine": "node --env-file=.env --test 'tests/engine/**/*.test.mjs'",
    "test:e2e": "node --env-file=.env --test tests/e2e/simple-test.mjs tests/e2e/minimal-real.test.mjs",
    "test:e2e:simple": "node --env-file=.env --test tests/e2e/simple-test.mjs",
    "test:e2e:minimal": "node --env-file=.env --test tests/e2e/minimal-real.test.mjs",
    "test:e2e:working": "node --env-file=.env --test tests/e2e/working-wallet.test.mjs",
    "test:e2e:wallet": "node --env-file=.env --test tests/e2e/wallet-operations.test.mjs",
    "test:e2e:dca": "node --env-file=.env --test tests/e2e/dca-strategy.test.mjs",
    "test:e2e:privacy": "node --env-file=.env --test tests/e2e/privacy-trading.test.mjs",
    "test:e2e:consensus": "node --env-file=.env --test tests/e2e/group-consensus.test.mjs",
    "test:e2e:signals": "node --env-file=.env --test tests/e2e/signal-automation.test.mjs",
    "test:all": "node --test 'tests/**/*.test.mjs'",
    "prepublishOnly": "npm test"
  },
  "imports": {
    "#zerion/*": "./*",
    "#zerion": "./package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "zerion",
    "ai",
    "wallet",
    "openclaw",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeriontech/zerion-ai.git"
  },
  "bugs": {
    "url": "https://github.com/zeriontech/zerion-ai/issues"
  },
  "homepage": "https://github.com/zeriontech/zerion-ai#readme",
  "license": "MIT",
  "dependencies": {
    "@open-wallet-standard/core": "^1.2.4",
    "@solana/web3.js": "^1.98.4",
    "@x402/evm": "^2.6.0",
    "@x402/fetch": "^2.6.0",
    "@x402/svm": "^2.8.0",
    "mppx": "^0.6.2",
    "qrcode-terminal": "^0.12.0",
    "viem": "^2.0.0"
  },
  "overrides": {
    "uuid": "^14.0.0"
  }
}
