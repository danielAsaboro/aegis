{
  "name": "@danielasaboro/aegis",
  "version": "1.0.0",
  "description": "Privacy-first autonomous trading agent. Natural language → policy-gated → shielded execution on Solana.",
  "author": "Daniel Asaboro <asaborodaniel@gmail.com>",
  "type": "module",
  "bin": {
    "zerion": "./cli/zerion.js",
    "aegis": "./engine/index.mjs"
  },
  "files": [
    "cli/zerion.js",
    "cli/router.js",
    "cli/commands/",
    "cli/utils/",
    "cli/policies/",
    "skills/",
    "plugins/",
    ".agents/",
    ".claude-plugin/",
    ".codex-plugin/",
    "gemini-extension.json",
    "prisma/schema.prisma",
    "scripts/db-init.mjs",
    "engine/**/*.mjs",
    "engine/studio/web/dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node --env-file=.env engine/index.mjs",
    "studio": "node --env-file=.env engine/index.mjs --studio",
    "studio:build": "cd engine/studio/web && pnpm install && pnpm build",
    "mcp": "node --env-file=.env engine/index.mjs mcp",
    "demo": "node --env-file=.env scripts/demo.mjs",
    "judge-trace": "node --env-file=.env scripts/judge-trace.mjs",
    "publish:ai-sdk-qvac": "cd packages/ai-sdk-qvac && npm publish --access public",
    "pack:ai-sdk-qvac": "cd packages/ai-sdk-qvac && npm pack",
    "qvac:download": "node scripts/qvac-download-models.mjs",
    "qvac:backfill": "node --env-file=.env scripts/qvac-backfill.mjs",
    "db:push": "node --env-file=.env scripts/db-init.mjs",
    "db:studio": "node --env-file=.env node_modules/prisma/build/index.js studio",
    "postinstall": "prisma generate || true",
    "test": "node --test 'cli/tests/unit/**/*.test.mjs' 'tests/unit/**/*.test.mjs'",
    "test:unit": "node --test 'cli/tests/unit/**/*.test.mjs' 'tests/unit/**/*.test.mjs'",
    "test:integration": "node --test --test-concurrency=1 'cli/tests/integration/**/*.test.mjs' 'tests/integration/**/*.test.mjs'",
    "test:integration:auth": "node --test cli/tests/integration/auth.test.mjs",
    "test:qvac": "node --test tests/unit/qvac/audio.test.mjs tests/unit/qvac/embeddings.test.mjs tests/unit/qvac/llm-parse.test.mjs tests/unit/qvac/ai-sdk-provider.test.mjs",
    "test:qvac:integration": "node --test --test-concurrency=1 tests/integration/rag-memory.test.mjs",
    "test:qvac:e2e": "node --test tests/e2e/qvac/voice-trade.test.mjs",
    "test:engine": "node --env-file=.env --test 'tests/engine/**/*.test.mjs'",
    "test:e2e": "node --env-file=.env --test tests/e2e/simple-test.mjs tests/e2e/minimal-real.test.mjs",
    "test:e2e:simple": "node --env-file=.env --test tests/e2e/simple-test.mjs",
    "test:e2e:minimal": "node --env-file=.env --test tests/e2e/minimal-real.test.mjs",
    "test:e2e:working": "node --env-file=.env --test tests/e2e/working-wallet.test.mjs",
    "test:e2e:wallet": "node --env-file=.env --test tests/e2e/wallet-operations.test.mjs",
    "test:e2e:dca": "node --env-file=.env --test tests/e2e/dca-strategy.test.mjs",
    "test:e2e:privacy": "node --env-file=.env --test tests/e2e/privacy-trading.test.mjs",
    "test:e2e:consensus": "node --env-file=.env --test tests/e2e/group-consensus.test.mjs",
    "test:e2e:signals": "node --env-file=.env --test tests/e2e/signal-automation.test.mjs",
    "test:all": "node --env-file=.env --test 'cli/tests/**/*.test.mjs' 'tests/**/*.test.mjs'",
    "tui": "cd tui && cargo run --release --",
    "tui:build": "cd tui && cargo build --release",
    "tui:dev": "cd tui && cargo run --",
    "prepublishOnly": "npm test"
  },
  "imports": {
    "#zerion/*": "./cli/*",
    "#zerion": "./package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "zerion",
    "ai",
    "wallet",
    "openclaw",
    "cli",
    "aegis",
    "solana",
    "trading-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielAsaboro/aegis.git"
  },
  "bugs": {
    "url": "https://github.com/danielAsaboro/aegis/issues"
  },
  "homepage": "https://github.com/danielAsaboro/aegis#readme",
  "license": "MIT",
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@magicblock-labs/ephemeral-rollups-sdk": "^0.11.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@open-wallet-standard/core": "^1.2.4",
    "@prisma/client": "^6",
    "@qvac/embed-llamacpp": "^0.14",
    "@qvac/llm-llamacpp": "^0.19",
    "@qvac/transcription-whispercpp": "^0.6",
    "@qvac/tts-onnx": "^0.8",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@x402/evm": "^2.6.0",
    "@x402/fetch": "^2.6.0",
    "@x402/svm": "^2.8.0",
    "ai": "^6",
    "bs58": "^6.0.0",
    "envalid": "^8.1.1",
    "fastify": "^5.8.5",
    "ffmpeg-static": "^5.2.0",
    "mppx": "^0.6.2",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "telegraf": "^4.16.3",
    "viem": "^2.0.0",
    "zod": "^3.25"
  },
  "devDependencies": {
    "bare-fs": "^4.7.1",
    "bare-os": "^3.9.0",
    "bare-path": "^3.0.0",
    "bare-process": "^4.4.1",
    "bare-runtime": "^1.28.4",
    "bare-runtime-darwin-arm64": "^1.28.4",
    "prisma": "^6"
  },
  "overrides": {
    "uuid": "^14.0.0"
  }
}
