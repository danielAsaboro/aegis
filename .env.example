# === Required ===
TELEGRAM_BOT_TOKEN=          # From @BotFather
ZERION_API_KEY=zk_dev_...    # From dashboard.zerion.io

# === Wallet ===
# The agent needs a wallet created via: zerion wallet create <name>
# Then create an agent token: zerion agent create-token <name> <wallet>
ZERION_AGENT_TOKEN=          # For unattended signing

# === Optional ===
COINGECKO_API_KEY=           # Better rate limits for price monitor
HELIUS_API_KEY=              # Better onchain data for whale tracking
PRICE_POLL_INTERVAL=60000    # Price monitor interval (ms), default 60s
PORTFOLIO_POLL_INTERVAL=300000  # Portfolio monitor interval (ms), default 5min
WHALE_POLL_INTERVAL=120000   # Whale monitor interval (ms), default 2min
DEFAULT_CHAIN=solana         # Default chain for trades
LOG_LEVEL=info               # debug | info | warn | error
DATA_DIR=~/.zerion/aegis     # Persistence directory

# === Database (Prisma SQLite) ===
# Relative paths resolve under DATA_DIR. Default lands in ~/.zerion/kraken/aegis.db.
AEGIS_DATABASE_URL=file:./aegis.db

# === MagicBlock Private Payments ===
MAGICBLOCK_RPC_URL=https://rpc.magicblock.app/devnet       # MagicBlock base RPC
MAGICBLOCK_EPHEMERAL_URL=https://devnet.magicblock.app     # Ephemeral rollup RPC

# Solana keypair for MagicBlock signing (required for private execution)
# Can be base58-encoded private key or JSON array of bytes
# Generate with: solana-keygen new --outfile ~/.config/solana/devnet.json
# Then: cat ~/.config/solana/devnet.json (copy the array)
SOLANA_PRIVATE_KEY=          # [u8;64] JSON array or base58 string

# === Privacy Settings ===
PRIVACY_MODE=auto            # off | on | auto (threshold-based)
PRIVACY_THRESHOLD_USD=100    # Use private execution above this USD amount
PRIVACY_TOKENS=SOL,USDC      # Always use private execution for these tokens

# === LLM Agent Layer (Vercel AI SDK 6) ===
# Active model. Format: <provider>/<model>
# Supported: openai/gpt-5, openai/gpt-4.1-mini, anthropic/claude-sonnet-4.5, anthropic/claude-opus-4.7
AEGIS_AGENT_MODEL=openai/gpt-5

# Provider keys — set the one(s) for the providers you intend to use
OPENAI_API_KEY=              # https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=           # https://console.anthropic.com/ (only if using anthropic/* models)

# Autonomy: off | advisory (LLM proposes, human approves) | autonomous (auto-execute when policies pass)
AEGIS_AGENT_AUTONOMY=advisory

# Cost guards
AEGIS_AGENT_MAX_INVOCATIONS_PER_HOUR=20    # Per-user/strategy hourly cap on agent turns
AEGIS_AGENT_SIGNAL_COOLDOWN_MS=300000      # Min ms between agent reactions to the same signal type

# Auto-execute cap for autonomous-signal mode. Trades whose structured-verdict
# sizeUsd exceeds this fall back to the advisory + approval flow even when
# AEGIS_AGENT_AUTONOMY=autonomous.
AEGIS_AUTO_EXECUTE_MAX_USD=10

# === AEGIS Daemon ===
# Path to the Unix domain socket the daemon listens on. Defaults to
# $DATA_DIR/daemon.sock when unset.
AEGIS_DAEMON_SOCK=

# === Notifier ===
# Telegram bot dedicated to autonomous-mode notifications. If AEGIS_*
# values are unset the legacy TELEGRAM_BOT_TOKEN is reused.
AEGIS_TELEGRAM_BOT_TOKEN=
AEGIS_TELEGRAM_CHAT_ID=

# Webhook URL — receives every notification fan-out. Optional HMAC
# secret signs the body in the X-Aegis-Signature header.
AEGIS_NOTIFY_WEBHOOK_URL=
AEGIS_NOTIFY_WEBHOOK_SECRET=

# Set to "0" to disable macOS osascript notifications on darwin.
AEGIS_NOTIFY_MACOS=1
