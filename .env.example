# === Required ===
TELEGRAM_BOT_TOKEN=          # From @BotFather
ZERION_API_KEY=zk_dev_...    # From dashboard.zerion.io

# === Wallet ===
# The agent needs a wallet created via: zerion wallet create <name>
# Then create an agent token: zerion agent create-token <name> <wallet>
ZERION_AGENT_TOKEN=          # For unattended signing

# === Optional ===
COINGECKO_API_KEY=           # Better rate limits for price monitor
HELIUS_API_KEY=              # Better onchain data for whale tracking
PRICE_POLL_INTERVAL=60000    # Price monitor interval (ms), default 60s
PORTFOLIO_POLL_INTERVAL=300000  # Portfolio monitor interval (ms), default 5min
WHALE_POLL_INTERVAL=120000   # Whale monitor interval (ms), default 2min
DEFAULT_CHAIN=solana         # Default chain for trades
LOG_LEVEL=info               # debug | info | warn | error
DATA_DIR=~/.zerion/aegis     # Persistence directory

# === MagicBlock Private Payments ===
MAGICBLOCK_RPC_URL=https://rpc.magicblock.app/devnet       # MagicBlock base RPC
MAGICBLOCK_EPHEMERAL_URL=https://devnet.magicblock.app     # Ephemeral rollup RPC

# Solana keypair for MagicBlock signing (required for private execution)
# Can be base58-encoded private key or JSON array of bytes
# Generate with: solana-keygen new --outfile ~/.config/solana/devnet.json
# Then: cat ~/.config/solana/devnet.json (copy the array)
SOLANA_PRIVATE_KEY=          # [u8;64] JSON array or base58 string

# === Privacy Settings ===
PRIVACY_MODE=auto            # off | on | auto (threshold-based)
PRIVACY_THRESHOLD_USD=100    # Use private execution above this USD amount
PRIVACY_TOKENS=SOL,USDC      # Always use private execution for these tokens
